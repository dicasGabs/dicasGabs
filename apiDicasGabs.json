		{
			"name": "Cadastrar usuarios",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Validar status 201 e mensagem de sucesso\", function () {\r",
							"    // Verifica status code\r",
							"    pm.expect(pm.response.code).to.eql(201);\r",
							"    \r",
							"    // Verifica mensagem no response\r",
							"    pm.expect(pm.response.text()).to.include(\"Cadastro realizado com sucesso\");\r",
							"});\r",
							"\r",
							"// Salva a resposta JSON para uso futuro\r",
							"const resposta = pm.response.json();\r",
							"pm.collectionVariables.set(\"idUsuario\", resposta._id);"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Lista de personagens de Star Wars e Senhor dos Anéis\r",
							"const personagens = [\r",
							"    // Star Wars\r",
							"    { nome: 'Luke Skywalker', universo: 'starwars' },\r",
							"    { nome: 'Leia Organa', universo: 'starwars' },\r",
							"    { nome: 'Han Solo', universo: 'starwars' },\r",
							"    { nome: 'Darth Vader', universo: 'starwars' },\r",
							"    { nome: 'Obi-Wan Kenobi', universo: 'starwars' },\r",
							"    { nome: 'Yoda', universo: 'starwars' },\r",
							"    { nome: 'Anakin Skywalker', universo: 'starwars' },\r",
							"    { nome: 'Padmé Amidala', universo: 'starwars' },\r",
							"    { nome: 'Rey', universo: 'starwars' },\r",
							"    { nome: 'Kylo Ren', universo: 'starwars' },\r",
							"    { nome: 'Finn', universo: 'starwars' },\r",
							"    { nome: 'Poe Dameron', universo: 'starwars' },\r",
							"    { nome: 'Ahsoka Tano', universo: 'starwars' },\r",
							"    { nome: 'Mace Windu', universo: 'starwars' },\r",
							"    { nome: 'Qui-Gon Jinn', universo: 'starwars' },\r",
							"    { nome: 'Lando Calrissian', universo: 'starwars' },\r",
							"    { nome: 'Chewbacca', universo: 'starwars' },\r",
							"    { nome: 'R2-D2', universo: 'starwars' },\r",
							"    { nome: 'C-3PO', universo: 'starwars' },\r",
							"    { nome: 'Boba Fett', universo: 'starwars' },\r",
							"    // Senhor dos Anéis\r",
							"    { nome: 'Frodo Baggins', universo: 'middleearth' },\r",
							"    { nome: 'Gandalf', universo: 'middleearth' },\r",
							"    { nome: 'Aragorn', universo: 'middleearth' },\r",
							"    { nome: 'Legolas', universo: 'middleearth' },\r",
							"    { nome: 'Gimli', universo: 'middleearth' },\r",
							"    { nome: 'Samwise Gamgee', universo: 'middleearth' },\r",
							"    { nome: 'Meriadoc Brandybuck', universo: 'middleearth' },\r",
							"    { nome: 'Peregrin Took', universo: 'middleearth' },\r",
							"    { nome: 'Boromir', universo: 'middleearth' },\r",
							"    { nome: 'Faramir', universo: 'middleearth' },\r",
							"    { nome: 'Éowyn', universo: 'middleearth' },\r",
							"    { nome: 'Théoden', universo: 'middleearth' },\r",
							"    { nome: 'Galadriel', universo: 'middleearth' },\r",
							"    { nome: 'Elrond', universo: 'middleearth' },\r",
							"    { nome: 'Arwen', universo: 'middleearth' },\r",
							"    { nome: 'Saruman', universo: 'middleearth' },\r",
							"    { nome: 'Sauron', universo: 'middleearth' },\r",
							"    { nome: 'Gollum', universo: 'middleearth' },\r",
							"    { nome: 'Bilbo Baggins', universo: 'middleearth' },\r",
							"    { nome: 'Thorin Oakenshield', universo: 'middleearth' }\r",
							"];\r",
							"\r",
							"// Embaralha o array usando algoritmo Fisher-Yates\r",
							"function embaralhar(array) {\r",
							"    const arrayEmbaralhado = [...array];\r",
							"    for (let i = arrayEmbaralhado.length - 1; i > 0; i--) {\r",
							"        const j = Math.floor(Math.random() * (i + 1));\r",
							"        [arrayEmbaralhado[i], arrayEmbaralhado[j]] = [arrayEmbaralhado[j], arrayEmbaralhado[i]];\r",
							"    }\r",
							"    return arrayEmbaralhado;\r",
							"}\r",
							"\r",
							"// Gera senha aleatória com letras, números e caracteres especiais\r",
							"function gerarSenha() {\r",
							"    const letras = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ';\r",
							"    const numeros = '0123456789';\r",
							"    const especiais = '!@#$%&*';\r",
							"    const todos = letras + numeros + especiais;\r",
							"\r",
							"    let senha = '';\r",
							"    senha += letras[Math.floor(Math.random() * letras.length)];\r",
							"    senha += numeros[Math.floor(Math.random() * numeros.length)];\r",
							"    senha += especiais[Math.floor(Math.random() * especiais.length)];\r",
							"\r",
							"    for (let i = 3; i < 12; i++) {\r",
							"        senha += todos[Math.floor(Math.random() * todos.length)];\r",
							"    }\r",
							"\r",
							"    return senha.split('').sort(() => Math.random() - 0.5).join('');\r",
							"}\r",
							"\r",
							"// Embaralha a lista e seleciona um personagem aleatório\r",
							"const personagensEmbaralhados = embaralhar(personagens);\r",
							"const personagemSelecionado = personagensEmbaralhados[Math.floor(Math.random() * personagensEmbaralhados.length)];\r",
							"\r",
							"const nomeAleatorio = personagemSelecionado.nome;\r",
							"const universo = personagemSelecionado.universo;\r",
							"\r",
							"// Gera email baseado no nome e universo\r",
							"const nomeParaEmail = nomeAleatorio\r",
							"    .toLowerCase()\r",
							"    .normalize('NFD')\r",
							"    .replace(/[\\u0300-\\u036f]/g, '')\r",
							"    .replace(/\\s+/g, '.')\r",
							"    .replace(/[^a-z0-9.]/g, '');\r",
							"\r",
							"// Separa primeiro e último nome\r",
							"const partesNome = nomeParaEmail.split('.');\r",
							"const primeiroNome = partesNome[0];\r",
							"const ultimoNome = partesNome[partesNome.length - 1];\r",
							"\r",
							"// Define domínio baseado no universo\r",
							"const dominio = universo === 'starwars' ? 'starwars.com' : 'middleearth.com';\r",
							"\r",
							"// Decide aleatoriamente entre ordem normal ou invertida\r",
							"const ordemInvertida = Math.random() < 0.5;\r",
							"\r",
							"// Timestamp de 5 dígitos (últimos 5 dígitos do timestamp)\r",
							"const timestamp = String(Date.now()).slice(-5);\r",
							"\r",
							"let emailGerado;\r",
							"if (ordemInvertida && partesNome.length > 1) {\r",
							"    emailGerado = `${ultimoNome}.${primeiroNome}.${timestamp}@${dominio}`;\r",
							"} else {\r",
							"    emailGerado = `${nomeParaEmail}.${timestamp}@${dominio}`;\r",
							"}\r",
							"\r",
							"// Gera senha\r",
							"const senhaGerada = gerarSenha();\r",
							"\r",
							"// Administrador sempre true\r",
							"const administrador = 'true';\r",
							"\r",
							"// Define as variáveis\r",
							"pm.collectionVariables.set('nome', nomeAleatorio);\r",
							"pm.collectionVariables.set('email', emailGerado);\r",
							"pm.collectionVariables.set('senha', senhaGerada);\r",
							"pm.collectionVariables.set('administrador', administrador);\r",
							"\r",
							"pm.environment.set('nome', nomeAleatorio);\r",
							"pm.environment.set('email', emailGerado);\r",
							"pm.environment.set('senha', senhaGerada);\r",
							"pm.environment.set('administrador', administrador);\r",
							"\r",
							"// Console log para todos\r",
							"console.log('===================================');\r",
							"console.log('DADOS GERADOS PARA CADASTRO');\r",
							"console.log('===================================');\r",
							"console.log('Nome:', nomeAleatorio);\r",
							"console.log('Email:', emailGerado);\r",
							"console.log('Senha:', senhaGerada);\r",
							"console.log('Administrador:', administrador);\r",
							"console.log('Universo:', universo);\r",
							"console.log('===================================');\r",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
